# All vars use M2V_ prefix. Without any .env, `docker compose up` just works
# serving potion-base-8M on port 22671.

# REQUIRED: Set an API key to protect your endpoints.
# Without this, the server will refuse to start unless you explicitly
# set M2V_AUTH_DISABLED=true (NOT recommended for production).
M2V_API_KEY=your-secret-token-here

# To explicitly disable auth (development only — NOT for production):
# M2V_AUTH_DISABLED=true

# Models configuration (comma-separated alias:path pairs)
# M2V_MODELS=base:minishlab/potion-base-8M,large:minishlab/potion-base-32M
# M2V_MODELS=multi:minishlab/potion-multilingual-128M,code:minishlab/potion-code-16M
# Local models must be under /models/, /opt/models/, or /data/models/
# M2V_MODELS=mymodel:/models/my-model

# HuggingFace token (for private/gated models)
# M2V_HF_TOKEN=hf_...

# Host port mapping (for docker-compose)
# PORT=9000

# Maximum batch size for embedding requests (default: 128)
# M2V_MAX_BATCH_SIZE=1024

# TLS: For production, run behind a reverse proxy (nginx, caddy, traefik)
# that handles TLS termination. Do NOT expose this service directly to the internet.
