# Example: serve two models simultaneously
#
# Copy to .env next to docker-compose.yml and adjust as needed.
# Without any .env, `docker compose up` serves potion-base-8M on port 22671.

# ── Two HuggingFace models ────────────────────────────────────────────────────
# MODELS=base:minishlab/potion-base-8M,large:minishlab/potion-base-32M

# ── Multilingual + code specialised models ────────────────────────────────────
# MODELS=multi:minishlab/potion-multilingual-128M,code:minishlab/potion-code-16M

# ── Local model directories (bind-mounted into the container) ─────────────────
# Add to docker-compose.yml volumes section:
#   - /absolute/host/path:/models/my-model:ro
# Then:
# MODELS=mymodel:/models/my-model

# ── Change host port ──────────────────────────────────────────────────────────
# PORT=9000

# ── Auth enabled ──────────────────────────────────────────────────────────────
# API_KEY=super-secret-token

# ── Private HuggingFace model ─────────────────────────────────────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# MODELS=private:my-org/my-private-model
